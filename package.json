{
  "name": "jzero-template-market",
  "version": "1.0.0",
  "description": "Jzero Template Market - Static website generator for showcasing templates",
  "main": "src/build.js",
  "scripts": {
    "build": "node src/build.js",
    "dev": "concurrently \"node src/build.js --watch\" \"npx serve dist\"",
