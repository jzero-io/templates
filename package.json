    "front-matter": "^4.0.2",
    "glob": "^10.3.10",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "serve": "^14.2.1"
  }
}
