<!-- Template Detail -->
<article class="template-detail">
  <div class="container">
    <header class="template-header-detail">
      <div class="template-meta">
        <span class="template-category"><%= template.category %></span>
      </div>

      <h1><%= template.name %></h1>
      <p class="template-description-large"><%= template.description %></p>

      <div class="template-tags-large">
        <% template.tags.forEach(tag => { %>
          <span class="tag"><%= tag %></span>
        <% }) %>
      </div>

      <div class="template-actions-detail">
        <div class="command-display">
          <code><%= template.command %></code>
          <button
            class="copy-button"
            onclick="copyCommand('<%= template.command %>')"
            title="<%= i18n.detail?.copyCommand || 'Copy command' %>"
            aria-label="<%= i18n.detail?.copyCommand || 'Copy command' %>"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
          </button>
        </div>

        <% if (template.repository) { %>
          <a href="<%= template.repository %>" target="_blank" rel="noopener" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            <span><%= i18n.card?.viewTemplate || 'View Template' %></span>
          </a>
        <% } %>
      </div>
    </header>

    <div class="template-content">
      <!-- Features -->
      <% if (template.features && template.features.length > 0) { %>
        <section class="template-features-section">
          <h2><%= i18n.detail?.features || 'Features' %></h2>
          <ul class="features-list">
            <% template.features.forEach(feature => { %>
              <li>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2"/>
                  <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <%= feature %>
              </li>
            <% }) %>
          </ul>
        </section>
      <% } %>

      <!-- Guide -->
      <% if (template.guide) { %>
        <section class="template-guide-section">
          <h2><%= i18n.detail?.gettingStarted || 'Getting Started Guide' %></h2>
          <div class="guide-content">
            <%- template.guide %>
          </div>
        </section>
      <% } %>
    </div>
  </div>
</article>

<!-- Toast Notification -->
<div id="toast" class="toast hidden">
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
    <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2"/>
    <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  </svg>
  <span><%= i18n.detail?.commandCopied || 'Command copied to clipboard!' %></span>
</div>

<script>
const currentLang = '<%= currentLang %>';

function copyCommand(command) {
  navigator.clipboard.writeText(command).then(() => {
    const toast = document.getElementById('toast');
    const copyButton = document.querySelector('.copy-button');

    // Show success state on button
    if (copyButton) {
      copyButton.classList.add('copied');
      setTimeout(() => {
        copyButton.classList.remove('copied');
      }, 1500);
    }

    // Show toast notification
    toast.classList.remove('hidden');
    setTimeout(() => {
      toast.classList.add('hidden');
    }, 2000);
  });
}
</script>
