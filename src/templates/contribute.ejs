<!-- Contribute Page -->
<section class="contribute-page">
  <div class="container">
    <div class="contribute-header">
      <h1><%= i18n.contribute?.pageTitle || 'Contribution Guide' %></h1>
      <p class="contribute-subtitle"><%= i18n.contribute?.pageSubtitle || 'Contribute your template to the Jzero Template Market' %></p>
    </div>

    <div class="contribute-content">
      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.whatIs || 'What are Third-party Templates?' %></h2>
        <p><%= i18n.contribute?.whatIsDescription || 'Third-party templates are project templates created and maintained by community developers.' %></p>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.structure || 'Template Structure' %></h2>
        <p><%= i18n.contribute?.structureDescription || 'Each third-party template should contain the following files:' %></p>
        <pre class="code-block"><code>your-template/
├── template.json          # Template config file (required)
├── template.zh.json       # Chinese config file (optional)
├── README.md              # Template documentation (required)
└── [template files]       # Template files and directories</code></pre>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.configFile || 'Configuration File' %></h2>
        <p><%= i18n.contribute?.configFileDescription || 'Template configuration file is in JSON format with the following fields:' %></p>
        <pre class="code-block"><code>{
  "id": "your-template-id",
  "name": "Your Template Name",
  "description": "A brief description of your template",
  "category": "Category Name",
  "tags": ["tag1", "tag2", "tag3"],
  "command": "jzero new project_name --template your-template-id",
  "repository": "https://github.com/username/repo",
  "demo": "https://your-demo-url.com",
  "features": [
    "Feature 1",
    "Feature 2",
    "Feature 3"
  ]
}</code></pre>

        <h3><%= i18n.contribute?.sections?.fields || '字段说明' %></h3>
        <table class="fields-table">
          <thead>
            <tr>
              <th><%= i18n.contribute?.table?.field || 'Field' %></th>
              <th><%= i18n.contribute?.table?.type || 'Type' %></th>
              <th><%= i18n.contribute?.table?.required || 'Required' %></th>
              <th><%= i18n.contribute?.table?.description || 'Description' %></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>id</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.id || 'Template unique identifier' %></td>
            </tr>
            <tr>
              <td><code>name</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.name || 'Template name' %></td>
            </tr>
            <tr>
              <td><code>description</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.description || 'Brief template description' %></td>
            </tr>
            <tr>
              <td><code>category</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.category || 'Template category' %></td>
            </tr>
            <tr>
              <td><code>tags</code></td>
              <td>array</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.tags || 'Template tag array' %></td>
            </tr>
            <tr>
              <td><code>command</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.command || 'Command to use template' %></td>
            </tr>
            <tr>
              <td><code>repository</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.no || '❌' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.repository || 'Template repository URL' %></td>
            </tr>
            <tr>
              <td><code>demo</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.no || '❌' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.demo || 'Online demo URL' %></td>
            </tr>
            <tr>
              <td><code>features</code></td>
              <td>array</td>
              <td><%= i18n.contribute?.table?.no || '❌' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.features || 'Template feature list' %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.multilingual || 'Multi-language Support' %></h2>
        <p><%= i18n.contribute?.multilingualDescription || 'To support Chinese, create a template.zh.json file:' %></p>
        <pre class="code-block"><code>{
  "id": "your-template-id",
  "name": "模板中文名称",
  "description": "模板的中文描述",
  "category": "分类名称",
  "tags": ["标签1", "标签2"],
  "command": "jzero new project_name --template your-template-id",
  "repository": "https://github.com/username/repo",
  "demo": "https://your-demo-url.com",
  "features": [
    "特性1",
    "特性2"
  ]
}</code></pre>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.bestPractices || 'Best Practices' %></h2>
        <ul class="contribute-list">
          <li><strong><%= i18n.contribute?.practices?.naming || 'Template Naming' %></strong>: <%= i18n.contribute?.namingDescription || 'Use meaningful names, recommended format: purpose-techstack-features' %></li>
          <li><strong><%= i18n.contribute?.practices?.categories || 'Category Selection' %></strong>: <%= i18n.contribute?.categoryDescription || 'Web, API, CLI, Mobile, Desktop, etc.' %></li>
          <li><strong><%= i18n.contribute?.practices?.tags || 'Tags Usage' %></strong>: <%= i18n.contribute?.tagsDescription || 'Add 3-8 related tags, including tech stack and project type' %></li>
          <li><strong><%= i18n.contribute?.practices?.docs || 'Documentation' %></strong>: <%= i18n.contribute?.docsDescription || 'README.md should include project introduction, features, and quick start guide' %></li>
        </ul>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.submit || 'Submit Template' %></h2>
        <ol class="contribute-steps">
          <li><%= i18n.contribute?.steps?.prepare || 'Prepare submission: Ensure complete template.json and README.md' %></li>
          <li><%= i18n.contribute?.steps?.fork || 'Fork this repository' %></li>
          <li><%= i18n.contribute?.steps?.create || 'Create your template in the third_party/ directory' %></li>
          <li><%= i18n.contribute?.steps?.pr || 'Create Pull Request' %></li>
          <li><%= i18n.contribute?.steps?.wait || 'Wait for review' %></li>
        </ol>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.help || '获取帮助' %></h2>
        <ul class="contribute-links">
          <li>
            <a href="https://github.com/jzero-io/templates/tree/main/third_party/README.<%= currentLang %>.md" target="_blank" rel="noopener">
              <%= i18n.contribute?.helpLinks?.readme || 'README' %>
            </a>
          </li>
          <li>
            <a href="https://github.com/jzero-io/templates/discussions" target="_blank" rel="noopener">
              <%= i18n.contribute?.helpLinks?.discussions || 'GitHub Discussions' %>
            </a>
          </li>
          <li>
            <a href="https://github.com/jzero-io/templates/issues" target="_blank" rel="noopener">
              <%= i18n.contribute?.helpLinks?.issues || '问题反馈' %>
            </a>
          </li>
        </ul>
      </div>

      <div class="contribute-cta">
        <h3><%= i18n.contribute?.cta?.title || 'Ready to Contribute?' %></h3>
        <p><%= i18n.contribute?.cta?.description || 'Start creating your template and help more developers!' %></p>
        <a href="https://github.com/jzero-io/templates/fork" target="_blank" rel="noopener" class="btn btn-primary">
          <%= i18n.contribute?.cta?.button || 'Fork Repository to Start' %>
        </a>
      </div>
    </div>
  </div>
</section>
