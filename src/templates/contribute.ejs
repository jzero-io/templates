<!-- Contribute Page -->
<section class="contribute-page">
  <div class="container">
    <div class="contribute-header">
      <h1><%= i18n.contribute?.pageTitle || 'Contribution Guide' %></h1>
      <p class="contribute-subtitle"><%= i18n.contribute?.pageSubtitle || 'Contribute your template to the Jzero Template Market' %></p>
    </div>

    <div class="contribute-content">
      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.whatIs || '什么是第三方模板？' %></h2>
        <p><%= i18n.contribute?.whatIsDescription || '第三方模板是由社区开发者创建并维护的项目模板，可以帮助其他开发者快速启动特定类型的项目。' %></p>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.structure || '模板结构' %></h2>
        <p><%= i18n.contribute?.structureDescription || '每个第三方模板需要包含以下文件：' %></p>
        <pre class="code-block"><code>your-template/
├── template.json          # 模板配置文件（必需）
├── template.zh.json       # 中文配置文件（可选）
├── README.md              # 模板说明文档（必需）
└── [template files]       # 模板文件和目录</code></pre>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.configFile || '配置文件说明' %></h2>
        <p><%= i18n.contribute?.configFileDescription || '模板配置文件是 JSON 格式，包含以下字段：' %></p>
        <pre class="code-block"><code>{
  "id": "your-template-id",
  "name": "Your Template Name",
  "description": "A brief description of your template",
  "category": "Category Name",
  "tags": ["tag1", "tag2", "tag3"],
  "command": "jzero new project_name --template your-template-id",
  "repository": "https://github.com/username/repo",
  "demo": "https://your-demo-url.com",
  "features": [
    "Feature 1",
    "Feature 2",
    "Feature 3"
  ]
}</code></pre>

        <h3><%= i18n.contribute?.sections?.fields || '字段说明' %></h3>
        <table class="fields-table">
          <thead>
            <tr>
              <th><%= i18n.contribute?.table?.field || '字段' %></th>
              <th><%= i18n.contribute?.table?.type || '类型' %></th>
              <th><%= i18n.contribute?.table?.required || '必需' %></th>
              <th><%= i18n.contribute?.table?.description || '说明' %></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>id</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.id || '模板唯一标识符' %></td>
            </tr>
            <tr>
              <td><code>name</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.name || '模板名称' %></td>
            </tr>
            <tr>
              <td><code>description</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.description || '模板简短描述' %></td>
            </tr>
            <tr>
              <td><code>category</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.category || '模板分类' %></td>
            </tr>
            <tr>
              <td><code>tags</code></td>
              <td>array</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.tags || '模板标签数组' %></td>
            </tr>
            <tr>
              <td><code>command</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.yes || '✅' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.command || '使用模板的命令' %></td>
            </tr>
            <tr>
              <td><code>repository</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.no || '❌' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.repository || '模板源码仓库地址' %></td>
            </tr>
            <tr>
              <td><code>demo</code></td>
              <td>string</td>
              <td><%= i18n.contribute?.table?.no || '❌' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.demo || '在线演示地址' %></td>
            </tr>
            <tr>
              <td><code>features</code></td>
              <td>array</td>
              <td><%= i18n.contribute?.table?.no || '❌' %></td>
              <td><%= i18n.contribute?.fieldDescriptions?.features || '模板特性列表' %></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.multilingual || '多语言支持' %></h2>
        <p><%= i18n.contribute?.multilingualDescription || '如果需要支持中文，创建 template.zh.json 文件：' %></p>
        <pre class="code-block"><code>{
  "id": "your-template-id",
  "name": "模板中文名称",
  "description": "模板的中文描述",
  "category": "分类名称",
  "tags": ["标签1", "标签2"],
  "command": "jzero new project_name --template your-template-id",
  "repository": "https://github.com/username/repo",
  "demo": "https://your-demo-url.com",
  "features": [
    "特性1",
    "特性2"
  ]
}</code></pre>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.bestPractices || '最佳实践' %></h2>
        <ul class="contribute-list">
          <li><strong><%= i18n.contribute?.practices?.naming || '模板命名' %></strong>: <%= i18n.contribute?.namingDescription || '使用有意义的名称，推荐格式：用途-技术栈-特性' %></li>
          <li><strong><%= i18n.contribute?.practices?.categories || '分类选择' %></strong>: <%= i18n.contribute?.categoryDescription || 'Web、API、CLI、Mobile、Desktop 等' %></li>
          <li><strong><%= i18n.contribute?.practices?.tags || '标签使用' %></strong>: <%= i18n.contribute?.tagsDescription || '添加 3-8 个相关标签，包含技术栈和项目类型' %></li>
          <li><strong><%= i18n.contribute?.practices?.docs || '文档编写' %></strong>: <%= i18n.contribute?.docsDescription || 'README.md 应包含项目简介、功能特性、快速开始指南' %></li>
        </ul>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.submit || '提交模板' %></h2>
        <ol class="contribute-steps">
          <li><%= i18n.contribute?.steps?.prepare || '准备提交：确保包含完整的 template.json 和 README.md' %></li>
          <li><%= i18n.contribute?.steps?.fork || 'Fork 本仓库' %></li>
          <li><%= i18n.contribute?.steps?.create || '在 third_party/ 目录下创建您的模板' %></li>
          <li><%= i18n.contribute?.steps?.pr || '创建 Pull Request' %></li>
          <li><%= i18n.contribute?.steps?.wait || '等待审核' %></li>
        </ol>
      </div>

      <div class="contribute-section">
        <h2><%= i18n.contribute?.sections?.help || '获取帮助' %></h2>
        <ul class="contribute-links">
          <li>
            <a href="https://github.com/jzero-io/templates/discussions" target="_blank" rel="noopener">
              <%= i18n.contribute?.helpLinks?.discussions || 'GitHub Discussions' %>
            </a>
          </li>
          <li>
            <a href="https://github.com/jzero-io/templates/issues" target="_blank" rel="noopener">
              <%= i18n.contribute?.helpLinks?.issues || '问题反馈' %>
            </a>
          </li>
        </ul>
      </div>

      <div class="contribute-cta">
        <h3><%= i18n.contribute?.cta?.title || '准备好贡献了吗？' %></h3>
        <p><%= i18n.contribute?.cta?.description || '开始创建您的模板，帮助更多开发者！' %></p>
        <a href="https://github.com/jzero-io/templates/fork" target="_blank" rel="noopener" class="btn btn-primary">
          <%= i18n.contribute?.cta?.button || 'Fork 仓库开始贡献' %>
        </a>
      </div>
    </div>
  </div>
</section>
