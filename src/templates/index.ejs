<!-- Hero Section -->
<section class="hero">
  <div class="container">
    <h1><%= siteTitle %></h1>
    <p class="hero-description"><%= siteDescription %></p>

    <div class="hero-cta">
      <a href="<%= baseUrl || '' %>/submit/index.html" class="btn btn-hero-submit">
        <%= i18n.submit?.heroButton %>
      </a>
    </div>

    <!-- Search -->
    <div class="search-container">
      <input
        type="text"
        id="searchInput"
        placeholder="<%= i18n.hero?.searchPlaceholder %>"
        class="search-input"
        autocomplete="off"
      >
      <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M9 17A8 8 0 1 0 9 1a8 8 0 0 0 0 16zM19 19l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </div>
  </div>
</section>

<!-- Filters -->
<section class="filters">
  <div class="container">
    <div class="filter-groups">
      <!-- Category Filter -->
      <div class="filter-group">
        <label><%= i18n.filters?.category %></label>
        <select id="categoryFilter" class="filter-select">
          <option value=""><%= i18n.filters?.allCategories %></option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="results-count">
      <span id="resultsCount"><%= templates.length %></span> <%= i18n.filters?.resultsCount %>
    </div>
  </div>
</section>

<!-- Templates Grid -->
<% const types = [
  { key: 'embedded', name: i18n.types?.embedded },
  { key: 'external', name: i18n.types?.external },
  { key: 'third_party', name: i18n.types?.third_party }
]; %>

<% types.forEach(type => { %>
  <% const typeTemplates = templates.filter(t => t.type === type.key); %>
  <% if (typeTemplates.length > 0 || type.key === 'third_party') { %>
    <section class="templates">
      <div class="container">
        <h2 class="type-title"><%= type.name %></h2>

        <% if (type.key === 'third_party') { %>
          <div class="contribution-card">
            <div class="contribution-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <div class="contribution-content">
              <h3><%= i18n.contribution?.title %></h3>
              <p><%= i18n.contribution?.description %></p>
              <a href="<%= baseUrl || '' %>/contribute/index.html" class="btn btn-contribution">
                <%= i18n.contribution?.button %>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
        <% } %>

        <div class="templates-grid" id="templatesGrid-<%= type.key %>">
          <% typeTemplates.forEach(template => { %>
            <article class="template-card" data-id="<%= template.id %>">
              <div class="template-header">
                <h2 class="template-title">
                  <a href="<%= baseUrl || '' %>/<%= template.type %>/<%= template.id %>/index.html"><%= template.name %></a>
                </h2>
                <span class="template-category"><%= template.category %></span>
              </div>

              <p class="template-description"><%= template.description %></p>

              <% if (template.features && template.features.length > 0) { %>
                <ul class="template-features">
                  <% template.features.slice(0, 3).forEach(feature => { %>
                    <li><%= feature %></li>
                  <% }) %>
                </ul>
              <% } %>

              <div class="template-tags">
                <% template.tags.forEach(tag => { %>
                  <span class="tag"><%= tag %></span>
                <% }) %>
              </div>

              <div class="template-actions">
                <a href="<%= baseUrl || '' %>/<%= template.type %>/<%= template.id %>/index.html" class="btn btn-primary">
                  <%= i18n.card?.viewDetails %>
                </a>
                <% if (template.demo) { %>
                  <a href="<%= template.demo %>" target="_blank" rel="noopener" class="btn btn-secondary">
                    <%= i18n.card?.liveDemo %>
                  </a>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>
<% }) %>

<% if (templates.length === 0) { %>
  <section class="templates">
    <div class="container">
      <div class="no-results">
        <h3><%= i18n.noResults?.title %></h3>
        <p><%= i18n.noResults?.description %></p>
      </div>
    </div>
  </section>
<% } %>

<a href="<%= baseUrl || '' %>/submit/index.html" class="floating-submit-button" aria-label="<%= i18n.submit?.floatingButton %>">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M12 5v14"/>
    <path d="M5 12h14"/>
  </svg>
  <span><%= i18n.submit?.floatingButton %></span>
</a>
